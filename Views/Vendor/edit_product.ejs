<section id="viewProduct" class="">
  <!-- A Vendor clicks on a single product to see all information about the products like;
  * the product name ✓
  * amount sold ✓
  * amount remaining ✓
  * revenue generated by this product ✓
  * product that is mostly bought together with it ✓
  * location of most people that buy it
  * sales growth this month and last
  
  
  ** This section has two buttons; edit and delete
 -->
  <button class="float-end my-5 btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#confirmDelete">
    <i class="fa fa-light fa-trash"></i>
    Remove Product
  </button>
  
  <form action="/edit-product/<%= currentProduct._id %>" method="PATCH" id="productInfo">
    <div id="productImage">
      
      <figure id="productImageOutput"
                                                                                                                              class="d-flex output-element justify-content-center my-5 mb-3 border border-1 w-100">
        <img src="https://via.placeholder.com/300" alt="image" />
      </figure>
      
      <div class="edit-input">
        <label class="d-block" for="productImageInput">
          <img id="productImageLabel" src="https://via.placeholder.com/300" alt="image" />
        </label>
        <input id="productImageInput" type="file" accept="image" hidden>
      </div>
    </div>
    
    <div class="product-name my-3">
      <a id="editName" class="p-1 float-end fs-6 fa fa-edit btn-edit text-success"></a>
      <h3 id="nameOutput" class="output-element display-3">
        <%= currentProduct.name %>
      </h3>
      
      <div class="edit-input">
        <input id="nameInput" class="input-element form-control" name="productName" value="<%= currentProduct.name %>">
        <button class="btn my-3  btn-save btn-outline-success text-end">Save Changes</button>
      </div>
    </div>
    <div class="product-desc my-4">
      <a id="editDescription" class="p-1 float-end fs-6 fa fa-edit btn-edit text-success"></a>
      <h6 class="display-6">Product description</h6>
      <p id="descOutput" class="output-element fs-6">
        <%= currentProduct.description %>
      </p>
      <div class="edit-input">
        
        <textarea id="descInput" class="input-element text-start form-text form-control" rows="5" name="description">
        <%= currentProduct.description %>
       </textarea>
        <button class="btn my-3 btn-save btn-outline-success text-end">Save Changes</button>
      </div>
    </div>
    <div class="product-amount my-3 text-center p-5">
      <a id="editQuantity" class="p-1 btn-edit float-end fs-6 fa fa-edit text-success"></a>
      <div class="text-heading">
        <h6 class="my-0 p-0 display-6">Product Quantity</h6>
        <p class="fs-6 my-0 p-0 fw-light text-muted">in stock</p>
      </div>
      <div class="d-flex my-3 justify-content-between">
        <div class="quantity-sold align-items-baseline d-flex">
          <span class="text-success fs-6">
            <%= currentProduct.amountSold %> sold
          </span>
          <i class="fa fa-arrow-up fa-3x text-success"></i>
        </div>
        <div class="quantity-remaining justify-content-between align-items-baseline d-flex">
          <i class="fa fa-arrow-down fa-3x text-danger"></i>
          <span class=" text-danger fs-6"> <i class="output-element">
              <%= currentProduct.amountInStock %>
            </i> remaining</span>
        </div>
      </div>
      <div class="edit-input">
        <input value="<%= currentProduct.amountInStock %>" class="input-element form-control col-4" type="number">
        <button class="btn my-3 btn-save btn-outline-success text-end">Save Changes</button>
      </div>
      
      <p class="text-muted mt-5">six times more than last month</p>
    </div>
  </form>
  <div class="product-card product-chart">
    <canvas id="salesChart"></canvas>
  </div>
  <div class="product-revenue text-center p-5">
    <div class="text-heading">
      <h6 class="my-0 p-0 display-6">Generated Revenue</h6>
      <p class="fs-6 my-0 p-0 fw-light text-muted">by this product</p>
    </div>
    <h4 class="display-2 my-4">
      <sup class="fs-6 p-0 fw-light algn-top">₦</sup>
      <%= currentProduct.generatedRevenue %>
    </h4>
  </div>
  <% if (currentProduct.isMostSold){ %>
    <div class="product-badge text-center p-5">
      <div class="text-heading">
        <h6 class="my-0 p-0 display-6">Most Sold Product</h6>
        <p class="fs-6 my-0 p-0 fw-light text-muted">by you; this month</p>
      </div>
      <h4 class="display-2 my-4">
        <i class="text-warning fa-3x fa-beat fas fa-trophy"></i>
      </h4>
    </div>
    <% } %>
      
      <% if(currentProduct.composite){%>
        <div class="product-composite text-center">
          <div class="text-heading">
            <h6 class="my-0 p-0 display-6">Several People Also Bought</h6>
            <p class="fs-6 my-0 p-0 fw-light text-muted">alongside this product</p>
          </div>
          <div class="border border-1 d-flex justify-content-center my-4 mb-2 w-100">
            <img src="https://via.placeholder.com/200" class="m-auto" alt="image">
          </div>
          <div class="product-info text-center">
            <p class="fs-4 mb-0">
              <%= currentProduct.composite.name %>
            </p>
            <a class="mb-4 mt-0 fs-6 text-decoration-underline"
                                                                                                                                    href="/preview/<%= currentProduct.composite._id %>">Learn
              more</a>
          </div>
        </div>
        <% } %>
          
</section>
